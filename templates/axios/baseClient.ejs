import Axios, { type AxiosPromise, type AxiosRequestConfig } from "axios";

export const axios = Axios.create({
  baseURL: '<%= it.baseUrl || '' %>',
  paramsSerializer: (params: any) =>
    encodeParams(params, null, {
      allowDots: <%= it.allowDots %>,
      arrayFormat: '<%= it.arrayFormat %>',
    }),
});

