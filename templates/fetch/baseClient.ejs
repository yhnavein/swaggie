export const defaults = {
  baseUrl: '<%= it.baseUrl || '' %>',
  paramsSerializer: (params: any) =>
    encodeParams(params, null, {
      allowDots: <%= it.allowDots %>,
      arrayFormat: '<%= it.arrayFormat %>',
    }),
};
<% if (it.responseShape === 'full') { %>
export interface <%= it.apiResponseType %><T> {
  data: T;
  headers: Headers;
  status: number;
}
<% } %>

